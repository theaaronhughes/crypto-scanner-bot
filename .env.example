# Copy to .env and fill only when you enable live trading (next phase).
# Public market data does not require keys.

BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_API_PASSPHRASE=

# Overrides config.json when set: true / false / 1 / 0
DRY_RUN=true

# Optional: path to config (default: config.json in project root)
# CONFIG_PATH=config.json
